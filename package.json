{
    "name": "ai-usage-monitor",
    "version": "0.1.2",
    "description": "A local-first desktop tray app for monitoring AI provider usage.",
    "author": "AI Usage Monitor",
    "main": "out/main/index.js",
    "type": "module",
    "packageManager": "pnpm@10.8.0",
    "scripts": {
        "preinstall": "node ./scripts/only-pnpm.mjs",
        "prepare": "husky",
        "predev": "node ./scripts/only-pnpm.mjs",
        "dev": "electron-vite dev",
        "prebuild": "node ./scripts/only-pnpm.mjs",
        "build": "tsc --noEmit && electron-vite build",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "verify": "pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build",
        "prepreview": "node ./scripts/only-pnpm.mjs",
        "preview": "electron-vite preview",
        "pretest": "node ./scripts/only-pnpm.mjs",
        "test": "vitest run",
        "prepack": "node ./scripts/only-pnpm.mjs",
        "pack": "pnpm run build && electron-builder --dir",
        "predist": "node ./scripts/only-pnpm.mjs",
        "dist": "pnpm run build && electron-builder"
    },
    "dependencies": {
        "@radix-ui/react-alert-dialog": "^1.1.17",
        "@radix-ui/react-select": "^2.3.1",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-switch": "^1.3.1",
        "@radix-ui/react-tooltip": "^1.2.10",
        "@tanstack/react-query": "^5.101.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron-updater": "^6.8.9",
        "framer-motion": "^12.41.0",
        "lucide-react": "^1.21.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "recharts": "^3.9.0",
        "sonner": "^2.0.7",
        "sql.js": "^1.14.1",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.1.0",
        "@commitlint/config-conventional": "^21.1.0",
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/utils": "^4.0.0",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.3.1",
        "@types/node": "^26.0.0",
        "@types/pngjs": "^6.0.5",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/sql.js": "^1.4.11",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/eslint-plugin": "^1.6.20",
        "electron": "^42.5.0",
        "electron-builder": "^26.15.3",
        "electron-vite": "^5.0.0",
        "eslint": "^10.5.0",
        "eslint-plugin-perfectionist": "^5.9.1",
        "eslint-plugin-react-compiler": "19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "eslint-plugin-react-x": "^5.9.2",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "png-to-ico": "^3.0.1",
        "pngjs": "^7.0.0",
        "postcss": "^8.5.15",
        "prettier": "^3.8.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.3.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "vitest": "^4.1.9"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller",
            "esbuild"
        ]
    },
    "build": {
        "appId": "com.aiusagemonitor.desktop",
        "productName": "AI Usage Monitor",
        "artifactName": "${name}-${version}-${os}-${arch}.${ext}",
        "directories": {
            "output": "release"
        },
        "publish": {
            "provider": "github",
            "owner": "RyanTheAllmighty",
            "repo": "ai-usage-monitor",
            "releaseType": "release"
        },
        "files": [
            "out/**",
            "assets/**",
            "node_modules/sql.js/dist/sql-wasm.wasm"
        ],
        "extraResources": [
            {
                "from": "node_modules/sql.js/dist/sql-wasm.wasm",
                "to": "node_modules/sql.js/dist/sql-wasm.wasm"
            }
        ],
        "icon": "assets/icon",
        "win": {
            "target": "nsis",
            "icon": "assets/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "assets/icon.icns"
        },
        "linux": {
            "target": "AppImage",
            "icon": "assets/icon.png",
            "category": "Utility"
        }
    }
}
